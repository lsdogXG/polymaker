# --- Secrets ---
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
SIGNATURE_TYPE=2
CHAIN_ID=137

API_KEY=
API_SECRET=
API_PASSPHRASE=

# --- Mongo ---
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=polymarket_arb

# --- Strategy ---
ENTRY_BUFFER=0.05
FEE_BUFFER=0.002
NEW_MARKET_WINDOW_SEC=60
SINGLE_LEG_TIMEOUT_SEC=25
GIFT_PRICE=0.02

# --- Risk ---
MAX_USDC_PER_TRADE=200
MAX_USDC_PER_MARKET=500
MAX_TOTAL_USDC=2000
MAX_UNHEDGED_SEC=1.5
STALE_BOOK_MS=1500

# --- Circuit Breaker ---
MAX_DAILY_LOSS=100
MAX_CONSECUTIVE_FAILURES=5
FAILURE_COOLDOWN_SEC=60

# --- Logging ---
LOG_DIR=./logs

# --- Enhanced Strategies (from poly-maker / spike-bot) ---
ENABLE_POSITION_MERGE=1
MIN_MERGE_SIZE=5
ENABLE_VOLATILITY_FILTER=1
MAX_VOLATILITY_PCT=0.15
MAX_SPREAD_PCT=0.05
ENABLE_STOP_LOSS=1
STOP_LOSS_PCT=-0.05
TRADE_COOLDOWN_SEC=30
MAX_HOLD_SEC=900

# --- Runtime ---
DRY_RUN=1
GAMMA_POLL_INTERVAL_SEC=1
CHUNK_MAX_SHARES=200
STATUS_LOG_INTERVAL_SEC=15

# --- Dashboard ---
# Generate token: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=
DASHBOARD_PORT=8080
